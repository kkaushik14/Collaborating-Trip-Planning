# Backend API base URL
# Use /api/v1 when frontend and backend are on same host behind a reverse proxy.
# Use http://<YOUR_EC2_PUBLIC_DNS_OR_IP>:3478/api/v1 when calling backend port directly.
VITE_API_BASE_URL=/api/v1

# Health check path on backend root
VITE_API_HEALTH_PATH=/health

# Keep false when testing real backend APIs
VITE_USE_API_MOCKS=false

# Keep false in production; only set true for explicit mock-only test builds
VITE_ALLOW_PROD_MOCKS=false

# Optional API timeout (ms)
VITE_API_TIMEOUT_MS=15000

# Optional delay for mock mode (ms)
VITE_MOCK_DELAY_MS=120
